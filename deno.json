{
  "name": "@yoonsung/rlm",
  "version": "0.3.1",
  "license": "LGPL-3.0-only",
  "exports": "./mod.ts",
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": true
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "mod.ts",
      "src/**/*.ts",
      ".env.example"
    ]
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --unstable-worker-options",
    "standalone": "deno run --allow-read --allow-write --allow-net=api.openai.com --unstable-worker-options src/standalone/main.ts",
    "coverage": "deno test --allow-read --allow-write --unstable-worker-options --coverage=coverage/raw && deno coverage --lcov --output=coverage/lcov.info coverage/raw && deno coverage --html coverage/raw",
    "coverage:raw": "deno test --allow-read --allow-write --unstable-worker-options --coverage=coverage/raw",
    "coverage:report": "deno coverage --lcov --output=coverage/lcov.info coverage/raw && deno coverage --html coverage/raw",
    "test:openai": "deno test --allow-read --allow-write --allow-net=api.openai.com --unstable-worker-options tests/openai_live_test.ts",
    "test:openai:integration": "deno test --allow-read --allow-write --allow-net=api.openai.com --unstable-worker-options --filter='^OpenAI integration' tests/openai_live_test.ts",
    "test:openai:synthetic": "deno test --allow-read --allow-write --allow-net=api.openai.com --unstable-worker-options --filter='^Synthetic ' tests/openai_live_test.ts",
    "test:openai:long-context": "deno test --allow-read --allow-write --allow-net=api.openai.com --unstable-worker-options tests/openai_long_context_benchmark.ts"
  }
}
